#!/bin/bash
# Hook VERSIONADO (se activa con `git config core.hooksPath hooks`, lo hace el
# script "prepare" de package.json en `npm install`).
#
# Dos capas:
#  1) Gate determinista de DISCO en TODO el sitio (check-plantilla +
#     check-indexabilidad): bloquea si hay severidad 'alta'. Cubre blog,
#     colonias y home (no solo servicios/).
#  2) validate-landing.sh sobre las landings de servicios/ staged (plantilla).

set -u

# --- Capa 0: NUNCA borrar una página VIVA (defensa anti-borrado, portada del plomero) ---
# Aunque el agente desatendido borre algo por error, aquí se ABORTA si un archivo eliminado
# (staged) sigue referenciado por una página viva o está en el sitemap. Los artefactos huérfanos
# de verdad (cero referencias, vía limpiar-huerfanos.py) pasan sin problema.
DELETED=$(git diff --cached --name-only --diff-filter=D 2>/dev/null || true)
if [ -n "$DELETED" ]; then
  DELPROB=""
  while IFS= read -r f; do
    [ -z "$f" ] && continue
    if [ "$f" = "index.html" ]; then DELPROB="$DELPROB
   - $f (la home NUNCA se borra)"; continue; fi
    case "$f" in
      */index.html) NEEDLE="${f%index.html}" ;;   # página: su URL de directorio
      *)            NEEDLE="$(basename "$f")" ;;   # otros: por basename
    esac
    if git grep -l --cached --fixed-strings "$NEEDLE" -- '*.html' '*.xml' '_redirects' >/dev/null 2>&1 \
       || grep -qF "$NEEDLE" sitemap.xml 2>/dev/null; then
      DELPROB="$DELPROB
   - $f (era página indexable / aún referenciado o en el sitemap)"
    fi
  done <<EOF
$DELETED
EOF
  if [ -n "$DELPROB" ]; then
    echo "❌ COMMIT BLOQUEADO: borrado ESTRUCTURAL (archivo en uso, no un huérfano):$DELPROB"
    echo "   Restáuralo o quita primero las referencias. (Huérfanos de verdad: limpiar-huerfanos.py)"
    exit 1
  fi
fi

# --- Capa 1: gate determinista site-wide ---
echo "🔍 Gate determinista (check-plantilla + check-indexabilidad)..."
if ! python3 .pipeline/ci-gate.py; then
    echo ""
    echo "❌ COMMIT BLOQUEADO: hay hallazgos de severidad ALTA (ver arriba)."
    echo "   Corre:  python3 .pipeline/ci-gate.py"
    exit 1
fi
echo ""

# --- Capa 2: validación de plantilla en landings de servicios staged ---
# Las colonias (servicios/electricista-colonias-culiacan/*/) usan OTRA plantilla
# (más ligera, no v2.0.0) y se excluyen de validate-landing.sh: su validación
# mecánica la cubre la Capa 1 (check-plantilla + check-indexabilidad).
STAGED_LANDINGS=$(git diff --cached --name-only --diff-filter=ACM | grep '^servicios/.*/index\.html$' | grep -v '/electricista-colonias-culiacan/')

if [ -z "$STAGED_LANDINGS" ]; then
    echo "✅ No hay landings de servicios modificadas; gate OK → commit permitido."
    exit 0
fi

echo "📄 Validando landings de servicios staged:"
echo "$STAGED_LANDINGS"
VALIDATION_FAILED=0
while IFS= read -r landing; do
    if [ -f "$landing" ]; then
        if ./validate-landing.sh "$landing"; then
            echo "✅ $landing"
        else
            echo "❌ $landing - VALIDACIÓN FALLIDA"
            VALIDATION_FAILED=1
        fi
    fi
done <<< "$STAGED_LANDINGS"

if [ $VALIDATION_FAILED -eq 1 ]; then
    echo "❌ COMMIT BLOQUEADO: una o más landings no pasaron validate-landing.sh"
    exit 1
fi

echo "✅ Gate + landings OK → commit permitido."
exit 0
